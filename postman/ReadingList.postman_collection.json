{
  "info": {
    "name": "Reading List API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Signup",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Reader\",\n  \"email\": \"reader@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "http://localhost:4000/api/auth/signup", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "auth", "signup"] }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"reader@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "http://localhost:4000/api/auth/login", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "auth", "login"] }
      }
    },
    {
      "name": "Create Book",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Learning Node\",\n  \"author\": \"Alex Express\",\n  \"isbn\": \"9781111111111\",\n  \"genre\": \"Tech\",\n  \"publishedYear\": 2026\n}"
        },
        "url": { "raw": "http://localhost:4000/api/books", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "books"] }
      }
    },
    {
      "name": "List Books",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:4000/api/books?search=Node", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "books"], "query": [{ "key": "search", "value": "Node" }] }
      }
    },
    {
      "name": "Create Review",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookId\": \"{{bookId}}\",\n  \"rating\": 5,\n  \"comment\": \"A great reference for Node projects.\"\n}"
        },
        "url": { "raw": "http://localhost:4000/api/reviews", "protocol": "http", "host": ["localhost"], "port": "4000", "path": ["api", "reviews"] }
      }
    }
  ]
}
